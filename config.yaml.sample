# Configuration file for AFN loans and fees report script

port: 25
username: ""
password: ""

# The directory to search for al-* school directories (e.g., /data/alma-stats)
scriptpath: ""

# Directory to copy sorted per-school reports into (e.g., /data/processed-files)
# Each school gets its own subdirectory. Leave empty to skip copying.
output_path: ""

# SMTP server for sending notification emails
smtpserver: ""

# The sending address
email_source: ""

# Subject line in email
email_subject: "Your AFN loans and fees report is ready for pick-up"

# Email body
message: "Please check your folder on the Scholars Portal server to pick up your loans and fees report"

# URL where schools pick up their reports
report_pickup_url: "https://app.globus.org/collections?scope=shared-with-me"
report_pickup_label: "Globus server"

# Contact email shown in the email footer
contact_email: "test@test.com"

# Script admin emails — receive the processing log after each run
script_admins:
  - ""
